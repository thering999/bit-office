{
  "name": "bit-office",
  "version": "1.2.2",
  "description": "Control AI agents from your phone — pixel office UI + real-time gateway",
  "type": "module",
  "bin": {
    "bit-office": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "cross-env NODE_ENV=development WS_PORT=9100 tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsup && shx cp src/*.js dist/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ably": "^2.6.0",
    "dotenv": "^16.4.0",
    "nanoid": "^5.0.0",
    "node-telegram-bot-api": "^0.67.0",
    "ws": "^8.18.0",
    "@office/shared": "workspace:*"
  },
  "devDependencies": {
    "@bit-office/orchestrator": "workspace:*",

    "@types/node": "^22.0.0",
    "@types/node-telegram-bot-api": "^0.64.13",
    "@types/ws": "^8.5.0",
    "cross-env": "^10.1.0",
    "shx": "^0.4.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "ai",
    "agent",
    "office",
    "gateway"
  ],
  "license": "MIT"
}
